# ── Supabase (Sandbox project, shared with other apps — Auth is shared too) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI Provider (used only by the "Regenerate" action) ──
OPENROUTER_API_KEY=

# ── Authorization ──
# Being authenticated only proves an account exists in the shared Supabase
# project — it does NOT mean the account should see this dashboard. Only
# emails listed here (comma-separated) can access AI Workforce, regardless
# of how many other unrelated users exist in auth.users.
ALLOWED_ADMIN_EMAILS=you@example.com
