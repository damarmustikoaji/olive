# ── Database (Supabase, schema "workforce", shared instance with Sandbox project) ──
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI Provider ──
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=

# ── GitHub (read-only PAT, scope: public_repo or repo) ──
# Named GH_TOKEN (not GITHUB_TOKEN) to avoid colliding with the auto-injected
# GITHUB_TOKEN that GitHub Actions provides to every workflow run.
GH_TOKEN=

# ── Runtime config ──
MAX_TASK_ATTEMPTS=3
WORK_HOURS_START=09:00
WORK_HOURS_END=17:00
WORK_TIMEZONE=Asia/Jakarta
